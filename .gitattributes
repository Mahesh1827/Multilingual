# Force LF line endings for all files in the repo
* text=auto eol=lf

# Explicitly enforce LF for workflow and config files
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
