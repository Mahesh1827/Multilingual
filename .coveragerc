[run]
source = .
omit =
    # Third-party
    .venv/*
    # Cache and artifacts
    .cache/*
    # CI/test files themselves
    tests/*
    # One-off scripts
    eval/*
    # Windows DLL path setup — not testable in CI
    _env_setup.py

[report]
exclude_lines =
    # Standard skip patterns
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    # Type checking blocks
    if TYPE_CHECKING:
    @(abc\.)?abstractmethod
