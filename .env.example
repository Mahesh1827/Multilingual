# ─────────────────────────────────────────────────────────────────────────
# Tirumala Multilingual AI Assistant — Environment Variables
#
# USAGE:
#   1. Copy this file:  copy .env.example .env  (Windows)
#                  OR:  cp .env.example .env     (Linux/macOS)
#   2. Fill in your API keys below.
#   3. Never commit your real .env file to git!
# ─────────────────────────────────────────────────────────────────────────

# ── LLM Provider: Groq (Primary) ─────────────────────────────────────────
# Get a free key at https://console.groq.com
# When set, the system uses Groq (cloud, very fast).
# When NOT set, the system falls back to local Ollama.
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq model to use (llama-3.3-70b-versatile is best for multilingual)
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM Provider: Ollama (Local Fallback) ────────────────────────────────
# Only used when GROQ_API_KEY is not set.
# Install Ollama from https://ollama.com and pull the model:
#   ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ── HuggingFace ───────────────────────────────────────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
# Required for downloading the multilingual-e5-large embedding model.
HF_TOKEN=hf_your_huggingface_token_here

# ── Web Search (Optional) ─────────────────────────────────────────────────
# Enables web search fallback when the RAG database lacks an answer.
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly_your_tavily_api_key_here
